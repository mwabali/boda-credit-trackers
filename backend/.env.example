PORT=5050
FLASK_DEBUG=0
SECRET_KEY=replace-this-in-production
AUTH_TOKEN_MAX_AGE_SECONDS=604800
CORS_ORIGINS=http://localhost:5173
# Optional: queued SMS alerts are delivered when a webhook is configured.
# SMS_WEBHOOK_URL=https://your-sms-provider.example/send
# SMS_WEBHOOK_TOKEN=replace-with-provider-token
# Africa's Talking sandbox is also supported directly.
# AFRICASTALKING_USERNAME=sandbox
# AFRICASTALKING_API_KEY=replace-with-api-key
# AFRICASTALKING_SMS_URL=https://api.sandbox.africastalking.com/version1/messaging
# For Supabase / Postgres on Render, set DATABASE_URL.
# DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres
